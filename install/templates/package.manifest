        {
            "kind": "Package",
            "name": "ESXi Device",
            "filename": "ESXi_Device.xml.gz",
            "metadata": {
                "author": "The Cacti Group",
                "homepage": "cacti.net",
                "email": "developers@cacti.net",
                "description": "ESXi Device Device Package",
                "class": "hypervisor",
                "tags": "vmware esxi hypervisor",
                "installation": "Infomation about this template:\nhttps:\/\/github.com\/Cacti\/documentation\/blob\/develop\/template_esxi_config.md\n\nLogin to the Hypervisor as root and then run the following commands to enable snmp support:\n\t\n\tesxcli system snmp set -r\n\tesxcli system snmp set -c YOUR_STRING\n\tesxcli system snmp set -p 161\n\tesxcli system snmp set -L \"City, State, Country\"\n\tesxcli system snmp set -C noc@example.com\n\tesxcli system snmp set -e yes\n\t\nGeneral information about Cacti templates:\nhttps:\/\/github.com\/Cacti\/documentation\/blob\/develop\/Device-Templates.md",
                "version": "1.3.0",
                "copyright": "GNU General Public License"
            }
        },
