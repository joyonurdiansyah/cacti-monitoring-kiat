        {
            "kind": "Package",
            "name": "ACME",
            "filename": "ACME.xml.gz",
            "metadata": {
                "author": "The Cacti Group",
                "homepage": "cacti.net",
                "email": "developers@cacti.net",
                "description": "ACME Device Package",
                "class": "linux",
                "tags": "ACME Packet Net-Net 4000 Series",
                "installation": "ACME Packet Net-Net 4000 Series contributed by alteleid on 03-04-2007.\n\nGeneral information about Cacti templates:\nhttps:\/\/github.com\/Cacti\/documentation\/blob\/develop\/Device-Templates.md",
