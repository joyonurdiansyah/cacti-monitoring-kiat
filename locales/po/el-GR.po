msgstr "Πώς θέλετε να χειρίζεστε τις γραμματοσειρές από προεπιλογή;"

#: include/global_settings.php:1425 lib/api_device.php:1615
msgid "System"
msgstr "Σύστημα"

#: include/global_settings.php:1430
