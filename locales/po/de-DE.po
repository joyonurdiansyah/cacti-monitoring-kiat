msgstr "Der Typ des generierten Diagramms: PNG, GIF oder SVG. Die Auswahl des Diagrammbildtyps hängt stark von RRDtool ab."

#: include/global_form.php:736
msgid "Height (--height)"
msgstr "Höhe (--height)"

#: include/global_form.php:740
