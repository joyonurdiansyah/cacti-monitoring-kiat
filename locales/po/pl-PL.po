msgstr "Liczba dni, tygodni, miesięcy lub lat do przechowywania statystyk miesięcznych."

#: include/global_settings.php:2723
msgid "Yearly Partition Retention"
msgstr "Zatrzymanie wskazania"

#: include/global_settings.php:2724
msgid "The number of Days, Weeks, Months, or Years to keep yearly statistics."
msgstr "Liczba dni, tygodni, miesięcy lub lat do prowadzenia statystyk rocznych."

#: include/global_settings.php:2730
msgid "RRDfile Check"
msgstr "Środek czyszczący RRDfile"

