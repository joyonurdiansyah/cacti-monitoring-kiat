#: include/global_form.php:713
msgid "Title (--title)"
msgstr "Titre II"

#: include/global_form.php:717
msgid "The name that is printed on the graph.  It can include replacement variables such as |host_description| or |query_fieldName|.  For a complete list of supported replacement tags, please see the Cacti documentation."
msgstr "Le nom qui est imprimé sur le graphique.  Il peut inclure des variables de remplacement telles que |host_description| ou |query_fieldName|.  Pour une liste complète des étiquettes de remplacement prises en charge, veuillez consulter la documentation Cacti."

#: include/global_form.php:721
