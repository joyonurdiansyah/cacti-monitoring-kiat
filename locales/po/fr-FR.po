msgstr "Il s'agit d'une longueur minimale des mots de passe autorisés."

#: include/global_settings.php:1927
msgid "Require Mix Case"
msgstr "Nécessite une mallette de mélange"

#: include/global_settings.php:1928
msgid "This will require new passwords to contains both lower and upper-case characters."
msgstr "Cela nécessitera que les nouveaux mots de passe contiennent à la fois des caractères minuscules et majuscules."

#: include/global_settings.php:1933
