# ============================================
# Cacti Docker Environment Variables
# ============================================
# Copy this file to .env and edit the values.
# cp .env.example .env
# ============================================

# --- Database Configuration ---
MYSQL_ROOT_PASSWORD=root_password_here
MYSQL_DATABASE=cacti
MYSQL_USER=cactiuser
MYSQL_PASSWORD=cacti_password_here

# --- Cacti Web Configuration ---
CACTI_URL_PATH=/cacti-monitoring/
CACTI_POLLER_INTERVAL=5
CACTI_POLLER_MAX_DURATION=120
CACTI_POLLER_PROCESSES=1

# --- Timezone ---
TZ=Asia/Jakarta

# --- Host Ports (change if ports are already in use) ---
CACTI_WEB_PORT=8090
CACTI_DB_PORT=3310
