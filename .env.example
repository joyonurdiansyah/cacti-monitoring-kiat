# Cacti Docker Configuration

# Web
WEB_PORT=8080
PHP_MEMORY_LIMIT=512M

# Database
# Change these before use; defaults are intentionally weak.
DB_ROOT_PASSWORD=root
DB_NAME=cacti
DB_USER=cacti
DB_PASSWORD=cacti
DB_PORT=3306

# Database Tuning
DB_MAX_CONNECTIONS=200
DB_BUFFER_POOL_SIZE=1G

# Timezone
TIMEZONE=UTC
