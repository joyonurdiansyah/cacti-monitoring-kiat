        "ext-gmp": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-ldap": "*",
        "ext-mbstring": "*",
        "ext-mysqlnd": "*",
        "ext-openssl": "*",
        "ext-pcntl": "*",
        "ext-pdo_mysql": "*",
        "ext-posix": "*",
        "ext-sockets": "*",
        "ext-sqlite3": "*",
        "ext-xml": "*",
        "ezyang/htmlpurifier": "^4.19",
        "paragonie/constant_time_encoding": "^2.0",
        "paragonie/random_compat": "*",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
    },
